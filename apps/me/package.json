{
  "name": "@afterroar/me",
  "version": "0.1.0",
  "private": true,
  "description": "Afterroar Passport — player identity, consent, data sovereignty. Served at afterroar.me.",
  "prisma": {
    "schema": "../../packages/database/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "prisma generate --schema=../../packages/database/prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "test:api": "vitest run",
    "test:api:watch": "vitest",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "test:visual": "playwright test"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/qrcode": "^1.5.6",
    "jose": "^6.0.11",
    "lucide-react": "^1.8.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
