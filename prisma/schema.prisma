generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// HQ-OWNED: User table (READ-ONLY from Store Ops)
// Must match HQ's User model. Store Ops never writes to this.
// Only fields Store Ops needs are declared here.
// ============================================================
model User {
  id           String  @id
  email        String  @unique
  displayName  String?
  avatarUrl    String?
  passwordHash String?

  pos_staff PosStaff[]

  @@map("User")
}

// ============================================================
// POS STORES
// ============================================================
model PosStore {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  owner_id   String?
  address    Json?
  settings   Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @db.Timestamptz()

  staff           PosStaff[]
  customers       PosCustomer[]
  inventory_items PosInventoryItem[]
  events          PosEvent[]
  ledger_entries  PosLedgerEntry[]
  trade_ins       PosTradeIn[]
  gift_cards      PosGiftCard[]
  suppliers       PosSupplier[]

  @@map("pos_stores")
}

// ============================================================
// POS STAFF (bridge: user_id → User.id)
// ============================================================
model PosStaff {
  id         String   @id @default(cuid())
  user_id    String
  store_id   String
  role       String   @default("cashier")
  name       String
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz()

  user           User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  ledger_entries PosLedgerEntry[]
  trade_ins      PosTradeIn[]

  @@unique([user_id, store_id])
  @@map("pos_staff")
}

// ============================================================
// POS CUSTOMERS
// ============================================================
model PosCustomer {
  id                   String   @id @default(cuid())
  store_id             String
  name                 String
  email                String?
  phone                String?
  credit_balance_cents Int      @default(0)
  loyalty_points       Int      @default(0)
  notes                String?
  afterroar_user_id    String?
  created_at           DateTime @default(now()) @db.Timestamptz()
  updated_at           DateTime @default(now()) @db.Timestamptz()

  store          PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  ledger_entries PosLedgerEntry[]
  trade_ins      PosTradeIn[]
  event_checkins PosEventCheckin[]

  @@index([store_id])
  @@map("pos_customers")
}

// ============================================================
// POS INVENTORY
// ============================================================
model PosInventoryItem {
  id                  String   @id @default(cuid())
  store_id            String
  name                String
  category            String
  sku                 String?
  barcode             String?
  price_cents         Int      @default(0)
  cost_cents          Int      @default(0)
  quantity            Int      @default(0)
  low_stock_threshold Int      @default(5)
  attributes          Json     @default("{}")
  image_url           String?
  external_id         String?
  supplier_id         String?
  lead_time_days      Int?
  reorder_point       Int?
  safety_stock        Int      @default(0)
  active              Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @default(now()) @db.Timestamptz()

  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  supplier       PosSupplier?     @relation(fields: [supplier_id], references: [id])
  trade_in_items PosTradeInItem[]

  @@index([store_id])
  @@index([store_id, category])
  @@index([barcode])
  @@index([store_id, sku])
  @@map("pos_inventory_items")
}

model PosSupplier {
  id                     String   @id @default(cuid())
  store_id               String
  name                   String
  contact                String?
  default_lead_time_days Int      @default(14)
  notes                  String?
  created_at             DateTime @default(now()) @db.Timestamptz()

  store PosStore           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  items PosInventoryItem[]

  @@map("pos_suppliers")
}

// ============================================================
// POS EVENTS
// ============================================================
model PosEvent {
  id                 String    @id @default(cuid())
  store_id           String
  name               String
  description        String?
  event_type         String?
  starts_at          DateTime  @db.Timestamptz()
  ends_at            DateTime? @db.Timestamptz()
  entry_fee_cents    Int       @default(0)
  max_players        Int?
  afterroar_event_id String?
  metadata           Json      @default("{}")
  created_at         DateTime  @default(now()) @db.Timestamptz()
  updated_at         DateTime  @default(now()) @db.Timestamptz()

  store          PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  checkins       PosEventCheckin[]
  ledger_entries PosLedgerEntry[]

  @@index([store_id])
  @@index([store_id, starts_at(sort: Desc)])
  @@map("pos_events")
}

model PosEventCheckin {
  id              String   @id @default(cuid())
  event_id        String
  customer_id     String
  checked_in_at   DateTime @default(now()) @db.Timestamptz()
  fee_paid        Boolean  @default(false)
  ledger_entry_id String?

  event    PosEvent    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  customer PosCustomer @relation(fields: [customer_id], references: [id])

  @@unique([event_id, customer_id])
  @@map("pos_event_checkins")
}

// ============================================================
// POS IMMUTABLE LEDGER
// ============================================================
model PosLedgerEntry {
  id                  String   @id @default(cuid())
  store_id            String
  type                String
  customer_id         String?
  staff_id            String?
  event_id            String?
  amount_cents        Int
  credit_amount_cents Int      @default(0)
  description         String?
  metadata            Json     @default("{}")
  created_at          DateTime @default(now()) @db.Timestamptz()

  store    PosStore     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer? @relation(fields: [customer_id], references: [id])
  staff    PosStaff?    @relation(fields: [staff_id], references: [id])
  event    PosEvent?    @relation(fields: [event_id], references: [id])

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, type])
  @@index([store_id, created_at(sort: Desc)])
  @@index([event_id])
  @@map("pos_ledger_entries")
}

// ============================================================
// POS TRADE-INS
// ============================================================
model PosTradeIn {
  id                   String    @id @default(cuid())
  store_id             String
  customer_id          String?
  staff_id             String?
  status               String    @default("pending")
  payout_type          String?
  total_offer_cents    Int       @default(0)
  credit_bonus_percent Decimal   @default(0) @db.Decimal(5, 2)
  total_payout_cents   Int       @default(0)
  notes                String?
  ledger_entry_id      String?
  created_at           DateTime  @default(now()) @db.Timestamptz()
  completed_at         DateTime? @db.Timestamptz()

  store    PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer?     @relation(fields: [customer_id], references: [id])
  staff    PosStaff?        @relation(fields: [staff_id], references: [id])
  items    PosTradeInItem[]

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, status])
  @@map("pos_trade_ins")
}

model PosTradeInItem {
  id                 String   @id @default(cuid())
  trade_in_id        String
  inventory_item_id  String?
  name               String
  category           String?
  attributes         Json     @default("{}")
  quantity           Int      @default(1)
  market_price_cents Int?
  offer_price_cents  Int
  created_at         DateTime @default(now()) @db.Timestamptz()

  trade_in       PosTradeIn        @relation(fields: [trade_in_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@map("pos_trade_in_items")
}

// ============================================================
// POS GIFT CARDS
// ============================================================
model PosGiftCard {
  id                       String   @id @default(cuid())
  store_id                 String
  code                     String   @unique
  balance_cents            Int      @default(0)
  initial_balance_cents    Int      @default(0)
  purchased_by_customer_id String?
  active                   Boolean  @default(true)
  created_at               DateTime @default(now()) @db.Timestamptz()
  updated_at               DateTime @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@map("pos_gift_cards")
}
